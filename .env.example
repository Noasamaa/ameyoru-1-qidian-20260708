# MySQL 8.x 连接串。utf8mb4 字符集支持中文与 emoji
DATABASE_URL=mysql://mo_user:mo_password@127.0.0.1:3306/mo?charset=utf8mb4

# better-auth
BETTER_AUTH_SECRET=please-change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# 仅 scripts/migrate-sqlite-to-mysql.ts 使用。指向旧 SQLite 文件
LEGACY_SQLITE_PATH=./data/mo.db
